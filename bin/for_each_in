# shellcheck disable=SC1001,SC1003,SC2001,SC2003,SC2016,SC2031,SC2090,SC2115,SC2120,SC2155,SC2199,SC2229,SC2317,SC2329
# - - - - - - - - - - - - - - - - - - - - - - - - -
APPNAME="${0##*/}"
VERSION="202605151243-git"
USER="${SUDO_USER:-$USER}"
export CASJAYSDEV_TITLE_PREV="${CASJAYSDEV_TITLE_PREV:-${CASJAYSDEV_TITLE_SET:-$APPNAME}}" CASJAYSDEV_TITLE_SET
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Initial debugging
[ "$1" = "--debug" ] && set -x && export SCRIPT_OPTS="--debug" && export _DEBUG="on"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Disables colorization
[ "$1" = "--no-color" ] && export SHOW_RAW="true"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# pipes fail
set -o pipefail
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Send all output to /dev/null
__devnull() {
  tee &>/dev/null && FOR_EACH_IN_EXIT_STATUS=0 || FOR_EACH_IN_EXIT_STATUS=1
  return ${FOR_EACH_IN_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# colorization — ANSI escapes directly (never tput); PRINTF_COLOR selects fg color (0–7)
if [ -n "${NO_COLOR+x}" ] || [ "$SHOW_RAW" = "true" ]; then
  __printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
else
  __printf_color() { printf '\e[3%sm%b\e[0m' "${PRINTF_COLOR:-7}" "$1"; }
fi
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Inline color helpers — each sets PRINTF_COLOR locally before calling __printf_color
__printf_red()     { local PRINTF_COLOR=1; __printf_color "$1\n"; }
__printf_green()   { local PRINTF_COLOR=2; __printf_color "$1\n"; }
__printf_yellow()  { local PRINTF_COLOR=3; __printf_color "$1\n"; }
__printf_blue()    { local PRINTF_COLOR=4; __printf_color "$1\n"; }
__printf_purple()  { local PRINTF_COLOR=5; __printf_color "$1\n"; }
__printf_cyan()    { local PRINTF_COLOR=6; __printf_color "$1\n"; }
__printf_newline() { printf '\n'; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Additional print helpers
__printf_head() { __printf_blue "$1"; }
__printf_opts() { __printf_purple "$1"; }
__printf_line() { __printf_cyan "$1"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# output version
__version() { __printf_cyan "$VERSION"; }
# - - - - - - - - - - - - - - - - - - - - - - - - -
# list options
__list_options() {
  local PRINTF_COLOR="${5:-4}"
  __printf_color "$1: "
  echo -ne "$2" | sed 's|:||g;s/'$3'/ '$4'/g' | tr '\n' ' '
  __printf_newline
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# create the config file
__gen_config() {
  if [ "$INIT_CONFIG" != "TRUE" ]; then
    __printf_blue "Generating the config file in"
    __printf_cyan "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE"
  fi
  [ -d "$FOR_EACH_IN_CONFIG_DIR" ] || mkdir -p "$FOR_EACH_IN_CONFIG_DIR"
  [ -d "$FOR_EACH_IN_CONFIG_BACKUP_DIR" ] || mkdir -p "$FOR_EACH_IN_CONFIG_BACKUP_DIR"
  [ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ] &&
    cp -Rf "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" "$FOR_EACH_IN_CONFIG_BACKUP_DIR/$FOR_EACH_IN_CONFIG_FILE.$$"
  cat <<EOF >"$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE"
# Settings for for_each_in

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Loop Behaviour Settings
FOR_EACH_IN_DRY_RUN="${FOR_EACH_IN_DRY_RUN:-no}"
FOR_EACH_IN_VERBOSE="${FOR_EACH_IN_VERBOSE:-no}"
FOR_EACH_IN_STOP_ON_ERROR="${FOR_EACH_IN_STOP_ON_ERROR:-no}"
FOR_EACH_IN_SUMMARY="${FOR_EACH_IN_SUMMARY:-no}"
FOR_EACH_IN_DELETE="${FOR_EACH_IN_DELETE:-no}"

EOF
  if builtin type -t __gen_config_local | grep -q 'function'; then __gen_config_local; fi
  if [ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ]; then
    [ "$INIT_CONFIG" = "TRUE" ] || __printf_green "Your config file for $APPNAME has been created"
    . "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE"
    FOR_EACH_IN_EXIT_STATUS=0
  else
    __printf_red "Failed to create the config file"
    FOR_EACH_IN_EXIT_STATUS=1
  fi
  return ${FOR_EACH_IN_EXIT_STATUS:-0}
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Help function - Align to 50
__help() {
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "for_each_in:  - $VERSION"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "Usage: for_each_in [options] \"PATTERN\" [CONDITIONS] COMMAND [ARGS...]"
  __printf_line " - "
  __printf_line "  PATTERN              Quoted glob                  e.g. \"./*\"  \"./*/*\""
  __printf_line " - "
  __printf_line "Conditions (bash test flags, all ANDed, repeatable):"
  __printf_line "  -e PATH              [ -e item/PATH ] — exists (any type)"
  __printf_line "  -f PATH              [ -f item/PATH ] — regular file"
  __printf_line "  -d PATH              [ -d item/PATH ] — directory"
  __printf_line "  -L PATH              [ -L item/PATH ] — symlink"
  __printf_line "  -r/-w/-x PATH        readable / writable / executable"
  __printf_line "  -s PATH              non-empty"
  __printf_line "  -b/-c/-p/-S PATH     block dev / char dev / pipe / socket"
  __printf_line "  -u/-g/-k PATH        setuid / setgid / sticky bit"
  __printf_line "  (empty or . as PATH → test the loop item itself)"
  __printf_line " - "
  __printf_line "Negation:"
  __printf_line "  --not -FLAG PATH     invert the immediately following condition"
  __printf_line " - "
  __printf_line "Source / destination (validated before loop starts):"
  __printf_line "  --source PATH        declare {source}; error if PATH does not exist"
  __printf_line "  --dest   PATH        declare {dest} AND gate on [ -e item/PATH ]"
  __printf_line "                       (shorthand for -e PATH + {dest} placeholder)"
  __printf_line " - "
  __printf_line "Loop behaviour:"
  __printf_line "  -n / --dry-run       print commands, do not run them"
  __printf_line "  -v / --verbose       print each command before running it"
  __printf_line "  --stop-on-error      halt on first non-zero exit"
  __printf_line "  --summary            print processed/skipped/failed count at end"
  __printf_line "  --delete             rm -Rf target before each command:"
  __printf_line "                         with --dest → removes {dest} (item/dest)"
  __printf_line "                         without     → removes {item} itself"
  __printf_line " - "
  __printf_line "Placeholders (substring-replaced inside any command argument):"
  __printf_line "  {item}  {dir}  \"\"    current loop item (full path)"
  __printf_line "  {item/.}  {dir/.}   item/.  — directory-contents form (cp/mv/rsync)"
  __printf_line "  {base}               basename of item              e.g. AI.md"
  __printf_line "  {name}               basename without extension     e.g. AI"
  __printf_line "  {ext}                extension with dot             e.g. .md"
  __printf_line "  {parent}             parent directory of item"
  __printf_line "  {source}             value of --source"
  __printf_line "  {source/.}           source/.  — directory-contents form"
  __printf_line "  {dest}               item/value-of-dest            e.g. ./proj/AI.md"
  __printf_line "  {dest/.}             item/dest/.  — directory-contents form"
  __printf_line " - "
  __printf_line "Examples:"
  __printf_line "  # Default pattern: copy source into every subdir that already has dest"
  __printf_line "  for_each_in \"./*\" -d . --source \"./AI.md\" --dest \"AI.md\" cp -Rfv \"{source}\" \"{dest}\""
  __printf_line " - "
  __printf_line "  # Rsync a directory's contents into each matching subdir"
  __printf_line "  for_each_in \"./*\" -d . --source \"./tmpl\" --dest \"conf\" rsync -avhP \"{source/.}\" \"{dest}/\""
  __printf_line " - "
  __printf_line "  # Copy dir contents without a fixed dest"
  __printf_line "  for_each_in \"./*\" -d . cp -Rfv \"{item/.}\" /backup/"
  __printf_line " - "
  __printf_line "  # Dry-run with summary"
  __printf_line "  for_each_in -n --summary \"./*\" -d . --source \"./AI.md\" --dest \"AI.md\" cp -Rfv \"{source}\" \"{dest}\""
  __printf_line " - "
  __printf_line "  # Skip symlinks, stop on first error"
  __printf_line "  for_each_in --stop-on-error \"./*\" --not -L . mv -fv \"{item/.}\" /archive/"
  __printf_line " - "
  __printf_line "  # Delete dest then copy source into it (cp variant)"
  __printf_line "  for_each_in \"./*\" -d . --source \"./AI.md\" --dest \"AI.md\" --delete cp -Rf \"{source}\" \"{dest}\""
  __printf_line "  # equivalent to: [ -e \"\$dir/AI.md\" ] && rm -Rf \"\$dir/AI.md\"; cp -Rf \"./AI.md\" \"\$dir/AI.md\""
  __printf_line " - "
  __printf_line "  # Delete dest then move source into it (mv variant)"
  __printf_line "  for_each_in \"./*\" -d . --source \"./AI.md\" --dest \"AI.md\" --delete mv -fv \"{source}\" \"{dest}\""
  __printf_line " - "
  __printf_line "  # Delete the item dir itself then replace with source"
  __printf_line "  for_each_in \"./*\" -d . --source \"./tmpl\" --delete cp -Rfv \"{source/.}\" \"{item}/\""
  __printf_line " - "
  __printf_line "--dir                           - Sets the working directory"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_opts "Other Options"
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
  __printf_line "--help                          - Shows this message"
  __printf_line "--config                        - Generate user config file"
  __printf_line "--version                       - Show script version"
  __printf_line "--options                       - Shows all available options"
  __printf_line "--debug                         - Enables script debugging"
  __printf_line "--no-color                      - Disable ANSI color output"
  __printf_line "--no                            - No options"
  __printf_line "--yes                           - Yes options"
  __printf_line ""
  __printf_head "- - - - - - - - - - - - - - - - - - - - - - - - -"
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
__trap_exit_for_each_in() {
  FOR_EACH_IN_EXIT_STATUS=${FOR_EACH_IN_EXIT_STATUS:-0}
  [ -f "$FOR_EACH_IN_TEMP_FILE" ] && rm -Rf "$FOR_EACH_IN_TEMP_FILE" &>/dev/null
  if builtin type -t __trap_exit_local | grep -q 'function'; then __trap_exit_local; fi
  return $FOR_EACH_IN_EXIT_STATUS
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup trap to remove temp file
trap '__trap_exit_for_each_in' EXIT
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Create a --no-* options function
__options_function_no() {
  local options="${1//=*/}"
  local argument="${1//*=/}"
  case "$options" in
  *) echo "${argument:-No argument provided}" && shift ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Create a --yes-* options function
__options_function_yes() {
  local options="${1//=*/}"
  local argument="${1//*=/}"
  case "$options" in
  *) echo "${argument:-No argument provided}" && shift ;;
  esac
}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# User defined functions
# - - - - - - - - - - - - - - - - - - - - - - - - -
__for_each_in_main() {
  local pattern="${1:-}"
  shift || true

  # Collect standard bash test flag + relative-path pairs.
  # Each condition is stored as three elements: negate(""|"!"), flag, path.
  # An empty or "." path tests the loop item itself; otherwise "$item/$path".
  # All conditions are ANDed — every one must pass for the item to be processed.
  local -a _conds=()
  local _negate="" _source="" _dest=""
  local _dry_run="${FOR_EACH_IN_DRY_RUN:-no}"
  local _verbose="${FOR_EACH_IN_VERBOSE:-no}"
  local _stop_on_error="${FOR_EACH_IN_STOP_ON_ERROR:-no}"
  local _summary="${FOR_EACH_IN_SUMMARY:-no}"
  local _delete="${FOR_EACH_IN_DELETE:-no}"

  while true; do
    case "${1:-}" in
    --not)           _negate="!";          shift 1 ;;
    --source)        _source="${2:-}";     shift 2 ;;
    --delete)        _delete="yes";        shift 1 ;;
    --dest)
      # --dest PATH: set {dest} placeholder AND implicitly gate on [ -e item/PATH ]
      _dest="${2:-}"
      _conds+=("" "-e" "$_dest")
      shift 2
      ;;
    --dry-run|-n)    _dry_run="yes";       shift 1 ;;
    --verbose|-v)    _verbose="yes";       shift 1 ;;
    --stop-on-error) _stop_on_error="yes"; shift 1 ;;
    --summary)       _summary="yes";       shift 1 ;;
    -b|-c|-d|-e|-f|-g|-G|-h|-k|-L|-N|-O|-p|-r|-s|-S|-u|-w|-x)
      _conds+=("$_negate" "$1" "${2:-}")
      _negate=""
      shift 2
      ;;
    *) break ;;
    esac
  done

  # Remaining args are the command + its arguments
  local -a cmd=("$@")

  # Validate pattern first
  if [ -z "$pattern" ]; then
    __printf_red "Usage: $APPNAME \"PATTERN\" [CONDITIONS] [OPTIONS] COMMAND [ARGS...]"
    return 2
  fi

  if [ ${#cmd[@]} -eq 0 ]; then
    __printf_red "No command specified"
    return 2
  fi

  # Validate {source} / {source/.} — must be declared if used, and must exist before loop starts
  local _cmd_str="${cmd[*]}"
  if [[ "$_cmd_str" == *"{source"* ]]; then
    if [ -z "$_source" ]; then
      __printf_red "{source} used in command but --source was not specified"
      return 2
    fi
    if [ ! -e "$_source" ]; then
      __printf_red "Source does not exist: $_source"
      return 2
    fi
  fi

  # Validate {dest} / {dest/.} — must be declared via --dest if used
  if [[ "$_cmd_str" == *"{dest"* ]] && [ -z "$_dest" ]; then
    __printf_red "{dest} used in command but --dest was not specified"
    return 2
  fi

  # Expand the glob inside the script (nullglob so unmatched patterns yield nothing)
  local _nullglob_was_set=0
  shopt -q nullglob && _nullglob_was_set=1
  shopt -s nullglob
  local -a _items=($pattern)
  (( _nullglob_was_set )) || shopt -u nullglob

  if [ ${#_items[@]} -eq 0 ]; then
    __printf_yellow "No matches for pattern: $pattern"
    return 0
  fi

  local _item _arg _neg _flag _rel _tp _i _skip _ret=0
  local _base _name _ext _parent
  local _count_processed=0 _count_skipped=0 _count_failed=0
  local -a _run_cmd

  for _item in "${_items[@]}"; do
    # Evaluate every condition; skip item on first failure
    _skip=0
    for (( _i=0; _i<${#_conds[@]}; _i+=3 )); do
      _neg="${_conds[$_i]}"
      _flag="${_conds[$((_i+1))]}"
      _rel="${_conds[$((_i+2))]}"
      if [ -z "$_rel" ] || [ "$_rel" = "." ]; then
        _tp="$_item"
      else
        _tp="$_item/$_rel"
      fi
      if [ "$_neg" = "!" ]; then
        [ "$_flag" "$_tp" ] && { _skip=1; break; } || true
      else
        [ "$_flag" "$_tp" ] || { _skip=1; break; }
      fi
    done
    if [ "$_skip" != "0" ]; then
      (( _count_skipped++ )) || true
      continue
    fi

    # --delete: remove the target before the main command runs.
    # Target is {dest} (item/dest) when --dest is set, otherwise {item} itself.
    if [ "$_delete" = "yes" ]; then
      local _del_target
      if [ -n "$_dest" ]; then
        _del_target="$_item/$_dest"
      else
        _del_target="$_item"
      fi
      if [ -e "$_del_target" ]; then
        if [ "$_verbose" = "yes" ] || [ "$_dry_run" = "yes" ]; then
          __printf_cyan "$(printf '%q ' rm -Rf "$_del_target")"
        fi
        if [ "$_dry_run" != "yes" ]; then
          rm -Rf "$_del_target" || {
            _ret=$?
            (( _count_failed++ )) || true
            __printf_red "Failed to delete: $_del_target (exit $_ret)"
            [ "$_stop_on_error" = "yes" ] && break
            continue
          }
        fi
      fi
    fi

    # Compute derived placeholders
    _base="$(basename -- "$_item")"
    _parent="$(dirname -- "$_item")"
    _ext="${_base##*.}"
    [ "$_ext" = "$_base" ] && _ext="" || _ext=".$_ext"
    _name="${_base%.*}"

    # Build the command with placeholder substitution (substring replacement).
    # {item} {dir} ""   →  current loop item (full path)
    # {item/.} {dir/.}  →  item/. — directory contents form for cp/mv/rsync
    # {base}            →  basename of item
    # {name}            →  basename without extension
    # {ext}             →  file extension including dot (e.g. .md)
    # {parent}          →  parent directory of item
    # {source}          →  value of --source (validated above)
    # {source/.}        →  source/. — directory contents form
    # {dest}            →  value of --dest (relative path within item)
    # {dest/.}          →  dest/. — directory contents form
    _run_cmd=()
    for _arg in "${cmd[@]}"; do
      if [ -z "$_arg" ]; then
        _run_cmd+=("$_item")
        continue
      fi
      # /. variants must be substituted before their base forms
      _arg="${_arg//\{item\/.\}/$_item/.}"
      _arg="${_arg//\{dir\/.\}/$_item/.}"
      _arg="${_arg//\{source\/.\}/$_source/.}"
      _arg="${_arg//\{dest\/.\}/$_item/$_dest/.}"
      _arg="${_arg//\{item\}/$_item}"
      _arg="${_arg//\{dir\}/$_item}"
      _arg="${_arg//\{base\}/$_base}"
      _arg="${_arg//\{name\}/$_name}"
      _arg="${_arg//\{ext\}/$_ext}"
      _arg="${_arg//\{parent\}/$_parent}"
      _arg="${_arg//\{source\}/$_source}"
      _arg="${_arg//\{dest\}/$_item/$_dest}"
      _run_cmd+=("$_arg")
    done

    # Show command when verbose or dry-run
    if [ "$_verbose" = "yes" ] || [ "$_dry_run" = "yes" ]; then
      __printf_cyan "$(printf '%q ' "${_run_cmd[@]}")"
    fi

    # Dry-run: count as processed but do not execute
    if [ "$_dry_run" = "yes" ]; then
      (( _count_processed++ )) || true
      continue
    fi

    if "${_run_cmd[@]}"; then
      (( _count_processed++ )) || true
    else
      _ret=$?
      (( _count_failed++ )) || true
      __printf_red "Failed (exit $_ret): $(printf '%q ' "${_run_cmd[@]}")"
      [ "$_stop_on_error" = "yes" ] && break
    fi
  done

  # Summary line
  if [ "$_summary" = "yes" ] || [ "$_verbose" = "yes" ]; then
    __printf_blue "Done — processed: $_count_processed  skipped: $_count_skipped  failed: $_count_failed"
  fi

  return $_ret
}

# - - - - - - - - - - - - - - - - - - - - - - - - -
# Default exit code
FOR_EACH_IN_EXIT_STATUS=0
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Application Folders
FOR_EACH_IN_CONFIG_DIR="${FOR_EACH_IN_CONFIG_DIR:-$HOME/.config/myscripts/for_each_in}"
FOR_EACH_IN_CONFIG_BACKUP_DIR="${FOR_EACH_IN_CONFIG_BACKUP_DIR:-$HOME/.local/share/myscripts/for_each_in/backups}"
FOR_EACH_IN_TEMP_DIR="${FOR_EACH_IN_TEMP_DIR:-$HOME/.local/tmp/system_scripts/for_each_in}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# File settings
FOR_EACH_IN_CONFIG_FILE="${FOR_EACH_IN_CONFIG_FILE:-settings.conf}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Loop Behaviour Settings
FOR_EACH_IN_DRY_RUN="${FOR_EACH_IN_DRY_RUN:-no}"
FOR_EACH_IN_VERBOSE="${FOR_EACH_IN_VERBOSE:-no}"
FOR_EACH_IN_STOP_ON_ERROR="${FOR_EACH_IN_STOP_ON_ERROR:-no}"
FOR_EACH_IN_SUMMARY="${FOR_EACH_IN_SUMMARY:-no}"
FOR_EACH_IN_DELETE="${FOR_EACH_IN_DELETE:-no}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Generate config files
[ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ] || [ "$*" = "--config" ] || INIT_CONFIG="${INIT_CONFIG:-TRUE}" __gen_config ${SETARGS:-$@}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Import config
[ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ] && . "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Ensure Directories exist
[ -d "$FOR_EACH_IN_TEMP_DIR" ] || mkdir -p "$FOR_EACH_IN_TEMP_DIR" |& __devnull
# - - - - - - - - - - - - - - - - - - - - - - - - -
FOR_EACH_IN_TEMP_FILE="${FOR_EACH_IN_TEMP_FILE:-$(mktemp $FOR_EACH_IN_TEMP_DIR/XXXXXX 2>/dev/null)}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Argument/Option settings
SETARGS=("$@")
# - - - - - - - - - - - - - - - - - - - - - - - - -
SHORTOPTS="+"
SHORTOPTS+="nv"
# - - - - - - - - - - - - - - - - - - - - - - - - -
LONGOPTS="completions:,config,reset-config,debug,dir:,help,options,no-color,version,silent,"
LONGOPTS+="dry-run,verbose,stop-on-error,summary,"
# - - - - - - - - - - - - - - - - - - - - - - - - -
ARRAY=""
ARRAY+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
LIST=""
LIST+=""
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Setup application options
setopts=$(getopt -o "$SHORTOPTS" --long "$LONGOPTS" -n "$APPNAME" -- "$@" 2>/dev/null)
eval set -- "${setopts[@]}" 2>/dev/null
while :; do
  case "$1" in
  --no-color)
    shift 1
    export SHOW_RAW="true"
    __printf_color() { printf '%b' "$1" | tr -d '\t' | sed '/^%b$/d;s,\x1B\[[0-9;]*[a-zA-Z],,g'; }
    ;;
  --debug)
    shift 1
    set -xo pipefail
    export SCRIPT_OPTS="--debug"
    export _DEBUG="on"
    __devnull() { tee || return 1; }
    ;;
  --completions)
    if [ "$2" = "short" ]; then
      printf '%s\n' "-$SHORTOPTS" | sed 's|"||g;s|:||g;s|,|,-|g' | tr ',' '\n'
    elif [ "$2" = "long" ]; then
      printf '%s\n' "--$LONGOPTS" | sed 's|"||g;s|:||g;s|,|,--|g' | tr ',' '\n'
    elif [ "$2" = "array" ]; then
      printf '%s\n' "$ARRAY" | sed 's|"||g;s|:||g' | tr ',' '\n'
    elif [ "$2" = "list" ]; then
      printf '%s\n' "$LIST" | sed 's|"||g;s|:||g' | tr ',' '\n'
    else
      exit 1
    fi
    shift 2
    exit $?
    ;;
  --options)
    shift 1
    __printf_blue "Current options for ${PROG:-$APPNAME}"
    [ -z "$SHORTOPTS" ] || __list_options "Short Options" "-${SHORTOPTS}" ',' '-' 4
    [ -z "$LONGOPTS" ] || __list_options "Long Options" "--${LONGOPTS}" ',' '--' 4
    [ -z "$ARRAY" ] || __list_options "Base Options" "${ARRAY}" ',' '' 4
    [ -z "$LIST" ] || __list_options "LIST Options" "${LIST}" ',' '' 4
    exit $?
    ;;
  --version)
    shift 1
    __version
    exit $?
    ;;
  --help)
    shift 1
    __help
    exit $?
    ;;
  --config)
    shift 1
    __gen_config
    exit $?
    ;;
  --reset-config)
    shift 1
    [ -f "$FOR_EACH_IN_CONFIG_DIR/$FOR_EACH_IN_CONFIG_FILE" ] && rm -Rf "${FOR_EACH_IN_CONFIG_DIR:?}/$FOR_EACH_IN_CONFIG_FILE"
    __gen_config
    exit $?
    ;;
  --silent)
    shift 1
    FOR_EACH_IN_SILENT="true"
    ;;
  --dir)
    CWD_IS_SET="TRUE"
    FOR_EACH_IN_CWD="$2"
    [ -d "$FOR_EACH_IN_CWD" ] || mkdir -p "$FOR_EACH_IN_CWD" |& __devnull
    shift 2
    ;;
  --dry-run|-n)
    shift 1
    FOR_EACH_IN_DRY_RUN="yes"
    ;;
  --verbose|-v)
    shift 1
    FOR_EACH_IN_VERBOSE="yes"
    ;;
  --stop-on-error)
    shift 1
    FOR_EACH_IN_STOP_ON_ERROR="yes"
    ;;
  --summary)
    shift 1
    FOR_EACH_IN_SUMMARY="yes"
    ;;
  --no-*)
    __options_function_no "$@"
    shift 1
    ;;
  --yes-*)
    __options_function_yes "$@"
    shift 1
    ;;
  --)
    shift 1
    break
    ;;
  esac
done
# - - - - - - - - - - - - - - - - - - - - - - - - -
FOR_EACH_IN_CWD="$(realpath "${FOR_EACH_IN_CWD:-$PWD}" 2>/dev/null)"
export FOR_EACH_IN_CWD
# - - - - - - - - - - - - - - - - - - - - - - - - -
# begin main app
__for_each_in_main "$@"
FOR_EACH_IN_EXIT_STATUS=$?
# - - - - - - - - - - - - - - - - - - - - - - - - -
# Set exit code
FOR_EACH_IN_EXIT_STATUS="${FOR_EACH_IN_EXIT_STATUS:-0}"
# - - - - - - - - - - - - - - - - - - - - - - - - -
# End application
# - - - - - - - - - - - - - - - - - - - - - - - - -
# lets exit with code
exit ${FOR_EACH_IN_EXIT_STATUS:-0}
# - - - - - - - - - - - - - - - - - - - - - - - - -
# ex: ts=2 sw=2 et filetype=sh
